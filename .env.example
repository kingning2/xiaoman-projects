# Production site URL for metadataBase, sitemap, canonical links
NEXT_PUBLIC_SITE_URL=https://kingning2.github.io/xiaoman-projects

# GitHub Pages 项目站必填子路径（与仓库名一致，前导斜杠）
NEXT_PUBLIC_BASE_PATH=/xiaoman-projects

# 以下仅配置在 GitHub Actions Secrets，不要写进本文件：
# xiaoman-projects 仓库: PORTFOLIO_REGISTER_KEY
# 各项目仓库: PORTFOLIO_PAT + PORTFOLIO_REGISTER_KEY
